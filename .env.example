# ============================================================================
# Farm Manager — Environment configuration
# Copy this file to `.env` and adjust for your environment.
# Never commit `.env` to git.
# ============================================================================

# ---------- Postgres ----------
POSTGRES_USER=farmmanager
POSTGRES_PASSWORD=farmmanager
POSTGRES_DB=farmmanager
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------- RabbitMQ ----------
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# ---------- MinIO (S3-compatible object storage) ----------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=farm-manager

# ---------- Seq (logs) ----------
SEQ_PORT=5341
SEQ_ADMIN_PASSWORD_HASH=

# ---------- Mailhog (dev SMTP catcher) ----------
MAILHOG_SMTP_PORT=1025
MAILHOG_WEB_PORT=8025

# ---------- API ----------
API_PORT=5000
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}
ConnectionStrings__Redis=redis:6379
ConnectionStrings__RabbitMq=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbitmq:5672
ConnectionStrings__Hangfire=Host=postgres;Port=5432;Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}

# ---------- JWT ----------
Jwt__Issuer=https://farm-manager.local
Jwt__Audience=farm-manager-web
Jwt__SigningKey=replace-with-at-least-32-byte-random-string-in-production
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=30

# ---------- Storage (MinIO) ----------
Storage__Endpoint=http://minio:9000
Storage__PublicEndpoint=http://localhost:9000
Storage__AccessKey=${MINIO_ROOT_USER}
Storage__SecretKey=${MINIO_ROOT_PASSWORD}
Storage__Bucket=${MINIO_BUCKET}

# ---------- WhatsApp Cloud API (Meta direct) ----------
# Get these from https://developers.facebook.com/apps/ → WhatsApp → Setup
WhatsApp__PhoneNumberId=
WhatsApp__AccessToken=
WhatsApp__VerifyToken=replace-with-random-string
WhatsApp__BusinessAccountId=

# ---------- Web Push (VAPID) ----------
# Generate with: npx web-push generate-vapid-keys
WebPush__Subject=mailto:owner@farm-manager.local
WebPush__PublicKey=
WebPush__PrivateKey=

# ---------- Email (SMTP) ----------
Smtp__Host=mailhog
Smtp__Port=1025
Smtp__User=
Smtp__Password=
Smtp__FromAddress=noreply@farm-manager.local
Smtp__FromName=Farm Manager

# ---------- Web ----------
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
NEXT_PUBLIC_WEBPUSH_PUBLIC_KEY=

# ---------- Caddy (prod) ----------
CADDY_DOMAIN=farm-manager.example.com
CADDY_EMAIL=admin@farm-manager.example.com

# ---------- Deploy ----------
DEPLOY_HOST=
DEPLOY_USER=deploy
DEPLOY_PATH=/srv/farm-manager
